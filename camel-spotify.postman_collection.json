{
  "info": {
    "name": "Camel Spotify API",
    "description": "Colección para probar la integración de Spotify API con Apache Camel + Spring Boot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url_cloud",
      "value": "https://merry-spirit-production-08fd.up.railway.app",
      "type": "string"
    },
    {
      "key": "base_url_local",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "base_url",
      "value": "https://merry-spirit-production-08fd.up.railway.app",
      "type": "string",
      "description": "Cambia este valor entre base_url_cloud y base_url_local"
    }
  ],
  "item": [
    {
      "name": "Tracks",
      "item": [
        {
          "name": "Buscar tracks - Radiohead",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/spotify/search?q=radiohead&type=track",
              "host": ["{{base_url}}"],
              "path": ["api", "spotify", "search"],
              "query": [
                { "key": "q", "value": "radiohead" },
                { "key": "type", "value": "track" }
              ]
            },
            "description": "Busca las 10 canciones más relevantes de Radiohead"
